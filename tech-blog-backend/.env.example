# Server
BLOG_PORT=3000
BLOG_NODE_ENV=development
BLOG_FRONTEND_URL=http://localhost:3001

# Database (PostgreSQL)
BLOG_DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=verify-full"

# JWT
BLOG_JWT_SECRET="your_jwt_secret_key"
BLOG_JWT_EXPIRES_IN=7d

# GitHub (for trending repos)
BLOG_GITHUB_TOKEN="your_github_personal_access_token"

# Gmail (for newsletter)
BLOG_GMAIL_USER="your_email@gmail.com"
BLOG_GMAIL_APP_PASSWORD="your_gmail_app_password"