generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  createdAt     DateTime       @default(now())
  isDisabled    Boolean        @default(false)
  password      String
  role          Role           @default(USER)
  subscriptions Subscription[]
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  posts     Post[]
}

model Post {
  id           String     @id @default(cuid())
  title        String
  slug         String     @unique
  shortDesc    String
  content      String
  thumbnailUrl String?
  source       String?
  status       PostStatus @default(DRAFT)
  scheduledAt  DateTime?
  publishedAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  categoryId   String
  category     Category   @relation(fields: [categoryId], references: [id])
}

model Subscription {
  id           String   @id @default(cuid())
  email        String
  userId       String
  topics       String[]
  deliveryTime String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])
}

model NewsletterLog {
  id        String   @id @default(cuid())
  topics    String[]
  totalSent Int
  status    String
  sentAt    DateTime @default(now())
}

model news_articles_automation {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String?
  content     String?
  image       String?
  link        String?   @unique(map: "idx_news_automation_link")
  author      String?
  date        DateTime? @db.Timestamptz(6)
  categories  String?
  source      String?
  total_stars Int?
  total_forks Int?
  language    String?
  created_at  DateTime? @default(now()) @db.Timestamptz(6)

  @@index([created_at(sort: Desc)], map: "idx_news_created_at")
}

enum Role {
  USER
  ADMIN
}

enum PostStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
}
